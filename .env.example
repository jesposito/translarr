# LLM provider: anthropic | openai | ollama | deepseek | gemini
LLM_PROVIDER=anthropic
LLM_MODEL=claude-sonnet-4-6

# Provider credentials (set whichever provider you chose)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
DEEPSEEK_API_KEY=
GEMINI_API_KEY=
OLLAMA_HOST=http://ollama:11434

# Where your media is mounted inside the container
MEDIA_ROOT=/media

# Translation defaults
TARGET_LANG=en
READING_RATE_CPS=17
MAX_CONCURRENT=2
CONTEXT_WINDOW_LINES=10

# Security
WEBHOOK_SECRET=

# Logging
LOG_LEVEL=INFO

# Cost guards
MAX_COST_CENTS_PER_DAY=1000
MAX_COST_CENTS_PER_JOB=500
JOB_TIMEOUT_SECONDS=1800

# Library refresh hooks (optional)
# After a translation completes, Translarr POSTs to Emby/Jellyfin
# so the new .srt is picked up immediately. Leave blank to skip.
EMBY_URL=
EMBY_API_KEY=
JELLYFIN_URL=
JELLYFIN_API_KEY=
LIBRARY_REFRESH_TIMEOUT_SECONDS=10

# Push notifications (optional)
# Use https://ntfy.sh/<your-topic> or self-hosted. Empty = off.
NTFY_URL=
