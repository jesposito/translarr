# LLM provider: anthropic | openai | ollama
LLM_PROVIDER=anthropic
LLM_MODEL=claude-sonnet-4-6

# Provider credentials (set whichever provider you chose)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OLLAMA_HOST=http://ollama:11434

# Media volume root inside the container
MEDIA_ROOT=/media

# Translation
TARGET_LANG=en
READING_RATE_CPS=17
MAX_CONCURRENT=2
CONTEXT_WINDOW_LINES=10

# Security
WEBHOOK_SECRET=

# Logging
LOG_LEVEL=INFO

# Library refresh hooks — after a translation completes, Translarr can POST to
# Emby/Jellyfin so the new .srt is picked up immediately (no waiting for the
# next scheduled scan). All optional; leave blank to skip.
#
# Emby: create an API key in Dashboard → API Keys.
EMBY_URL=
EMBY_API_KEY=
# Jellyfin: Dashboard → API Keys.
JELLYFIN_URL=
JELLYFIN_API_KEY=
# Bound on each refresh call (seconds).
LIBRARY_REFRESH_TIMEOUT_SECONDS=10
